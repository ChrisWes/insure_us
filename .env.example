# US Intelligence Monitor — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# EDGAR User-Agent (required by SEC fair-use policy — must identify your organisation)
# Format: "Organisation Name email@domain.com"
EDGAR_USER_AGENT=InsureMonitorUS your@email.com

# Adzuna API (https://developer.adzuna.com/)
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# NewsAPI (https://newsapi.org/) — free tier: 100 req/day
NEWS_API_KEY=your_newsapi_key

# Anthropic API (for LLM commentary)
ANTHROPIC_API_KEY=your_anthropic_key

# Email settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your@email.com
EMAIL_TO=recipient@email.com
